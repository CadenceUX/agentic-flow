{
  "version": 1,
  "environments": {
    "cadenceux": {
      "description": "CadenceUX anthropic-skills pack (fmp-dev-*, filemaker-xml, claris-filemaker-pro, ...)",
      "skills": ["anthropic-skills:*"],
      "paths": ["*/skills-plugin/*"]
    },
    "fmaiac": {
      "description": "FMAIAC FileMaker plugin (agents, fm-reference catalog, build/patch tooling)",
      "skills": ["FileMaker:*"],
      "agents": ["FileMaker:*"],
      "commands": [
        "fm-build", "patch-runner", "fm-slot-fill", "fm-saxml-export",
        "fms-admin", "fm-odata", "fm-addon-build", "fm-applescript",
        "fm-solution-init", "fm-standards-resolve", "fm-schema-diff"
      ],
      "paths": ["~/.claude/plugins/cache/fmaiac/*"]
    },
    "agentic-fm": {
      "description": "Agentic-FM skill pack and MCP server",
      "skills": ["agentic-fm:*"],
      "mcp": ["mcp__agentic-fm__*"]
    },
    "proofkit": {
      "description": "ProofKit skill pack and MCP server",
      "skills": ["proofkit:*"],
      "mcp": ["mcp__proofkit__*"]
    }
  },
  "shared": {
    "description": "Delivery utilities every environment may use (clipboard writes, previews)",
    "commands": ["fm-clipboard-write", "fm-clipboard-decode", "fm-renderer", "fm-calc-write"]
  },
  "policy": {
    "default": "warn",
    "unknown": "warn",
    "pairs": {
      "agentic-fm|proofkit": "gate"
    }
  },
  "projects": {
    "/Users/darrin/Desktop/Project": "fmaiac"
  }
}
